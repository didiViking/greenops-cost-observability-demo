{
  "title": "GreenOps Observability Dashboard",
  "description": "Cloud cost and sustainability observability powered by SPRUCE, VictoriaMetrics and Grafana",
  "tags": [
    "greenops",
    "spruce",
    "victoriametrics",
    "azure",
    "sustainability"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 0,
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 4,
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Total Cloud Cost (€)",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(cloud_cost)"
        }
      ]
    },
    
    {
      "id": 3,
      "type": "stat",
      "title": "Operational Energy (kWh)",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(cloud_operational_energy_kwh)"
        }
      ]
    }, 
    
    {
      "id": 4,
      "type": "stat",
      "title": "Operational Emissions (gCO₂e)",
