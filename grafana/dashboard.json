{
  "title": "GreenOps Cloud Cost Dashboard",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "2026-07-01T00:00:00Z",
    "to": "2026-07-08T00:00:00Z"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Cloud Cost (€)",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(cloud_cost)"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Estimated CO₂",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(cloud_co2_estimate)"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Cloud Cost Over Time",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(cloud_cost)"
        }
      ]
    },
    {
      "id": 4,
      "type": "barchart",
      "title": "Cost by Service",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "sum by(service)(cloud_cost)"
        }
      ]
    },
    {
      "id": 5,
      "type": "barchart",
      "title": "Cost by Category",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum by(category)(cloud_cost)"
        }
      ]
    },
    {
      "id": 6,
      "type": "barchart",
      "title": "Cost by Region",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum by(region)(cloud_cost)"
        }
      ]
    },
    {
      "id": 7,
      "type": "barchart",
      "title": "Top 10 Costly SKUs",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "topk(10, sum by(sku)(cloud_cost))"
        }
      ]
    },
    {
      "id": 8,
      "type": "barchart",
      "title": "Cost by Resource Group",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum by(resource_group)(cloud_cost)"
        }
      ]
    },
    {
      "id": 9,
      "type": "barchart",
      "title": "Estimated CO₂ by Region",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "expr": "sum by(region)(cloud_co2_estimate)"
        }
      ]
    },
    {
      "id": 10,
      "type": "barchart",
      "title": "VM Inventory",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "targets": [
        {
          "expr": "count by(sku)(cloud_resource_info{category=\"Compute\"})"
        }
      ]
    }
  ]
}
